FRONTEND_ORIGIN=http://127.0.0.1:3000
OPEN_METEO_GEOCODING_URL=https://geocoding-api.open-meteo.com/v1/search
OPEN_METEO_FORECAST_URL=https://api.open-meteo.com/v1/forecast
MODEL_ARTIFACT_PATH=artifacts/outbreak_rf_v1.joblib
OUTBREAK_DB_PATH=outbreak_radar.db
WEATHER_CACHE_TTL_SECONDS=900
WEATHER_CACHE_MAX_ENTRIES=512
HISTORY_MAX_PAGE_SIZE=50
CSV_FILENAME_PREFIX=alerts-history
CSV_FILENAME_TIMEZONE=UTC
# ASSISTANT_PROVIDER=openai
# ASSISTANT_API_KEY=<YOUR_API_KEY>    # DO NOT COMMIT REAL KEYS. Set this locally in backend/.env or via environment variables.
# To use Anthropic/Claude set ASSISTANT_PROVIDER=anthropic and provide an Anthropic key
ASSISTANT_OPENAI_MODEL=gpt-3.5-turbo
## Example for Anthropic (do not commit real keys):
# ASSISTANT_PROVIDER=anthropic
# ASSISTANT_API_KEY=<YOUR_API_KEY>    
